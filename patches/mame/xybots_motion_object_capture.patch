+
+void xybots_state::xybots_write_debug_layer(const char *path, const bitmap_argb32 &sprite_layer, const std::vector<xybots_mo_capture_record> &objects)
+{
+	bitmap_argb32 debug(sprite_layer.width(), sprite_layer.height());
+	for (int y = 0; y < sprite_layer.height(); y++)
+	{
+		u32 *const dst = &debug.pix(y);
+		u32 const *const src = &sprite_layer.pix(y);
+		for (int x = 0; x < sprite_layer.width(); x++)
+			dst[x] = src[x];
+	}
+
+	for (xybots_mo_capture_record const &object : objects)
+	{
+		if (!object.visible)
+			continue;
+
+		xybots_draw_debug_rect(debug, object.rendered_x, object.rendered_y, object.width_tiles * 8, object.height_tiles * 8, rgb_t(255, 255, 0));
+		xybots_draw_debug_text(debug, object.rendered_x, object.rendered_y, util::string_format("%02d", object.slot), rgb_t(255, 255, 255));
+		xybots_draw_debug_text(debug, object.rendered_x, object.rendered_y + 6, util::string_format("C:%04X", object.code), rgb_t(255, 255, 0));
+	}
+
+	xybots_write_png(path, debug);
+}
+
+
+void xybots_state::xybots_draw_debug_rect(bitmap_argb32 &bitmap, int x, int y, int width, int height, rgb_t color)
+{
+	auto plot = [&bitmap, color] (int px, int py)
+	{
+		if (px >= 0 && px < bitmap.width() && py >= 0 && py < bitmap.height())
+			bitmap.pix(py, px) = color;
+	};
+
+	for (int px = x; px < x + width; px++)
+	{
+		plot(px, y);
+		plot(px, y + height - 1);
+	}
+	for (int py = y; py < y + height; py++)
+	{
+		plot(x, py);
+		plot(x + width - 1, py);
+	}
+}
+
+
+void xybots_state::xybots_draw_debug_text(bitmap_argb32 &bitmap, int x, int y, const std::string &text, rgb_t color)
+{
+	static const u8 font[17][5] =
+	{
+		{ 0x7, 0x5, 0x5, 0x5, 0x7 }, // 0
+		{ 0x2, 0x6, 0x2, 0x2, 0x7 }, // 1
+		{ 0x7, 0x1, 0x7, 0x4, 0x7 }, // 2
+		{ 0x7, 0x1, 0x7, 0x1, 0x7 }, // 3
+		{ 0x5, 0x5, 0x7, 0x1, 0x1 }, // 4
+		{ 0x7, 0x4, 0x7, 0x1, 0x7 }, // 5
+		{ 0x7, 0x4, 0x7, 0x5, 0x7 }, // 6
+		{ 0x7, 0x1, 0x1, 0x1, 0x1 }, // 7
+		{ 0x7, 0x5, 0x7, 0x5, 0x7 }, // 8
+		{ 0x7, 0x5, 0x7, 0x1, 0x7 }, // 9
+		{ 0x7, 0x5, 0x7, 0x5, 0x5 }, // A
+		{ 0x6, 0x5, 0x6, 0x5, 0x6 }, // B
+		{ 0x7, 0x4, 0x4, 0x4, 0x7 }, // C
+		{ 0x6, 0x5, 0x5, 0x5, 0x6 }, // D
+		{ 0x7, 0x4, 0x6, 0x4, 0x7 }, // E
+		{ 0x7, 0x4, 0x6, 0x4, 0x4 }, // F
+		{ 0x0, 0x2, 0x0, 0x2, 0x0 }  // :
+	};
+
+	auto char_index = [] (char ch) -> int
+	{
+		if (ch >= '0' && ch <= '9')
+			return ch - '0';
+		if (ch >= 'A' && ch <= 'F')
+			return 10 + ch - 'A';
+		if (ch >= 'a' && ch <= 'f')
+			return 10 + ch - 'a';
+		if (ch == ':')
+			return 16;
+		return -1;
+	};
+
+	int cursor = x;
+	for (char ch : text)
+	{
+		int const index = char_index(ch);
+		if (index >= 0)
+		{
+			for (int row = 0; row < 5; row++)
+				for (int col = 0; col < 3; col++)
+					if (font[index][row] & (1 << (2 - col)))
+					{
+						int const px = cursor + col;
+						int const py = y + row;
+						if (px >= 0 && px < bitmap.width() && py >= 0 && py < bitmap.height())
+							bitmap.pix(py, px) = color;
+					}
+		}
+		cursor += 4;
+	}
+}
