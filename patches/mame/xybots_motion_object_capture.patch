+bool xybots_state::xybots_bitmap_has_pixels(const bitmap_ind16 &bitmap)
+{
+	for (int y = 0; y < bitmap.height(); y++)
+		for (int x = 0; x < bitmap.width(); x++)
+			if (bitmap.pix(y, x) != 0xffff)
+				return true;
+	return false;
+}
+
+
+u64 xybots_state::xybots_hash_bitmap(const bitmap_ind16 &bitmap)
+{
+	u64 hash = 1469598103934665603ULL;
+	auto mix = [&hash] (u64 value)
+	{
+		hash ^= value;
+		hash *= 1099511628211ULL;
+	};
+
+	mix(bitmap.width());
+	mix(bitmap.height());
+	for (int y = 0; y < bitmap.height(); y++)
+		for (int x = 0; x < bitmap.width(); x++)
+			mix(bitmap.pix(y, x));
+	return hash;
+}
+
+
+u64 xybots_state::xybots_hash_bitmap(const bitmap_argb32 &bitmap)
+{
+	u64 hash = 1469598103934665603ULL;
+	auto mix = [&hash] (u64 value)
+	{
+		hash ^= value;
+		hash *= 1099511628211ULL;
+	};
+
+	mix(bitmap.width());
+	mix(bitmap.height());
+	for (int y = 0; y < bitmap.height(); y++)
+		for (int x = 0; x < bitmap.width(); x++)
+			mix(bitmap.pix(y, x));
+	return hash;
+}
