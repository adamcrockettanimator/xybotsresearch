+void xybots_state::xybots_write_png(const char *path, const bitmap_argb32 &bitmap)
+{
+	emu_file file(machine().options().snapshot_directory(), OPEN_FLAG_WRITE | OPEN_FLAG_CREATE | OPEN_FLAG_CREATE_PATHS);
+	std::error_condition const filerr = file.open(path);
+	if (filerr)
+	{
+		osd_printf_error("[xybots-capture] Error opening %s (%s)\n", path, filerr.message().c_str());
+		return;
+	}
+
+	util::png_info pnginfo;
+	std::error_condition const pngerr = util::png_write_bitmap(file, &pnginfo, bitmap, 0, nullptr);
+	if (pngerr)
+		osd_printf_error("[xybots-capture] Error writing %s (%s)\n", path, pngerr.message().c_str());
+}
