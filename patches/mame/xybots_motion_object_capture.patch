+void xybots_state::xybots_auto_capture_frame(screen_device &screen, const rectangle &cliprect)
+{
+	std::vector<xybots_mo_capture_record> objects;
+	xybots_collect_motion_objects(objects);
+
+	std::string const capture_dir = "xybots_capture/auto";
+	xybots_create_capture_dirs(capture_dir + "/strips", false);
+	xybots_create_capture_dirs(capture_dir + "/stitched", false);
+	xybots_create_capture_dirs(capture_dir + "/characters", false);
+
+	int new_strips = 0;
+	int new_stitched = 0;
+	int new_characters = 0;
+	std::vector<int> stitch_candidates;
+	std::vector<rectangle> candidate_rects;
+
+	for (int index = 0; index < objects.size(); index++)
+	{
+		xybots_mo_capture_record &object = objects[index];
+		bitmap_ind16 object_ind(object.width_tiles * 8, object.height_tiles * 8);
+		xybots_render_object_bitmap(object, object_ind);
+		object.visible = xybots_bitmap_has_pixels(object_ind);
+		if (!object.visible)
+			continue;
+
+		u64 const strip_hash = xybots_hash_bitmap(object_ind);
+		if (m_xybots_seen_strips.insert(strip_hash).second)
+		{
+			m_xybots_unique_strip_index++;
+			std::string const image = util::string_format(
+					"%s/strips/strip_%05d_slot_%02d_code_%04X_h%d_c%d_p%d.png",
+					capture_dir,
+					m_xybots_unique_strip_index,
+					object.slot,
+					object.code,
+					object.height_tiles,
+					object.color,
+					object.priority);
+
+			bitmap_argb32 object_argb(object_ind.width(), object_ind.height());
+			xybots_convert_mobitmap(object_argb, object_ind, object_ind.cliprect());
+			xybots_write_png(image.c_str(), object_argb);
+			new_strips++;
+		}
+
+		rectangle screen_rect;
+		if (xybots_screen_rect(object, cliprect, screen_rect))
+		{
+			stitch_candidates.push_back(index);
+			candidate_rects.push_back(screen_rect);
+		}
+	}
+
+	std::vector<bool> consumed(stitch_candidates.size(), false);
+	for (int start = 0; start < stitch_candidates.size(); start++)
+	{
+		if (consumed[start])
+			continue;
+
+		std::vector<int> group;
+		std::vector<int> queue;
+		consumed[start] = true;
+		queue.push_back(start);
+
+		while (!queue.empty())
+		{
+			int const current = queue.back();
+			queue.pop_back();
+			group.push_back(current);
+
+			xybots_mo_capture_record const &current_object = objects[stitch_candidates[current]];
+			for (int other = 0; other < stitch_candidates.size(); other++)
+			{
+				if (consumed[other])
+					continue;
+
+				xybots_mo_capture_record const &other_object = objects[stitch_candidates[other]];
+				if (current_object.color != other_object.color || current_object.priority != other_object.priority)
+					continue;
+				if (!xybots_group_rects_touch(candidate_rects[current], candidate_rects[other]))
+					continue;
+
+				consumed[other] = true;
+				queue.push_back(other);
+			}
+		}
+
+		if (group.size() < 2)
+			continue;
+
+		rectangle bounds = candidate_rects[group[0]];
+		for (int member : group)
+			bounds |= candidate_rects[member];
+
+		if (bounds.width() > 96 || bounds.height() > 96)
+			continue;
+
+		bitmap_argb32 stitched(bounds.width(), bounds.height());
+		stitched.fill(rgb_t::transparent());
+		for (int member : group)
+		{
+			xybots_mo_capture_record const &object = objects[stitch_candidates[member]];
+			bitmap_ind16 object_ind(object.width_tiles * 8, object.height_tiles * 8);
+			xybots_render_object_bitmap(object, object_ind);
+
+			bitmap_argb32 object_argb(object_ind.width(), object_ind.height());
+			xybots_convert_mobitmap(object_argb, object_ind, object_ind.cliprect());
+			xybots_blit_argb(stitched, object_argb, object.rendered_x - bounds.left(), object.rendered_y - bounds.top());
+		}
+
+		u64 const stitched_hash = xybots_hash_bitmap(stitched);
+		if (m_xybots_seen_stitched.insert(stitched_hash).second)
+		{
+			m_xybots_unique_stitched_index++;
+			std::string const image = util::string_format(
+					"%s/stitched/stitched_%05d_frame_%llu_parts_%d.png",
+					capture_dir,
+					m_xybots_unique_stitched_index,
+					(unsigned long long)screen.frame_number(),
+					int(group.size()));
+			xybots_write_png(image.c_str(), stitched);
+			new_stitched++;
+		}
+	}
+
+	std::vector<bool> character_consumed(stitch_candidates.size(), false);
+	for (int start = 0; start < stitch_candidates.size(); start++)
+	{
+		if (character_consumed[start])
+			continue;
+
+		std::vector<int> group;
+		std::vector<int> queue;
+		character_consumed[start] = true;
+		queue.push_back(start);
+
+		while (!queue.empty())
+		{
+			int const current = queue.back();
+			queue.pop_back();
+			group.push_back(current);
+
+			xybots_mo_capture_record const &current_object = objects[stitch_candidates[current]];
+			for (int other = 0; other < stitch_candidates.size(); other++)
+			{
+				if (character_consumed[other])
+					continue;
+
+				xybots_mo_capture_record const &other_object = objects[stitch_candidates[other]];
+				if (current_object.color != other_object.color || current_object.priority != other_object.priority)
+					continue;
+				if (!xybots_group_rects_character_related(candidate_rects[current], candidate_rects[other]))
+					continue;
+
+				rectangle trial_bounds = candidate_rects[current];
+				trial_bounds |= candidate_rects[other];
+				if (trial_bounds.width() > 96 || trial_bounds.height() > 112)
+					continue;
+
+				character_consumed[other] = true;
+				queue.push_back(other);
+			}
+		}
+
+		if (group.size() < 2)
+			continue;
+
+		rectangle bounds = candidate_rects[group[0]];
+		for (int member : group)
+			bounds |= candidate_rects[member];
+
+		if (bounds.width() > 96 || bounds.height() > 112)
+			continue;
+
+		bitmap_argb32 character(bounds.width(), bounds.height());
+		character.fill(rgb_t::transparent());
+		for (int member : group)
+		{
+			xybots_mo_capture_record const &object = objects[stitch_candidates[member]];
+			bitmap_ind16 object_ind(object.width_tiles * 8, object.height_tiles * 8);
+			xybots_render_object_bitmap(object, object_ind);
+
+			bitmap_argb32 object_argb(object_ind.width(), object_ind.height());
+			xybots_convert_mobitmap(object_argb, object_ind, object_ind.cliprect());
+			xybots_blit_argb(character, object_argb, object.rendered_x - bounds.left(), object.rendered_y - bounds.top());
+		}
+
+		u64 const character_hash = xybots_hash_bitmap(character);
+		if (m_xybots_seen_characters.insert(character_hash).second)
+		{
+			m_xybots_unique_character_index++;
+			std::string const image = util::string_format(
+					"%s/characters/character_%05d_frame_%llu_parts_%d.png",
+					capture_dir,
+					m_xybots_unique_character_index,
+					(unsigned long long)screen.frame_number(),
+					int(group.size()));
+			xybots_write_png(image.c_str(), character);
+			new_characters++;
+		}
+	}
+
+	if (new_strips || new_stitched || new_characters)
+		osd_printf_info("[xybots-capture] frame %llu: %d new strips, %d new stitched, %d new characters\n", (unsigned long long)screen.frame_number(), new_strips, new_stitched, new_characters);
+}
+
