+std::string xybots_state::xybots_snapshot_root()
+{
+	std::string snapshot_root = machine().options().snapshot_directory();
+	auto const path_separator = snapshot_root.find(';');
+	if (path_separator != std::string::npos)
+		snapshot_root.erase(path_separator);
+	if (snapshot_root.empty())
+		snapshot_root = ".";
+	return snapshot_root;
+}
+
+
+void xybots_state::xybots_create_capture_dirs(const std::string &capture_dir, bool objects_dir)
+{
+	std::filesystem::path path = std::filesystem::path(xybots_snapshot_root()) / capture_dir;
+	if (objects_dir)
+		path /= "objects";
+	std::error_code direrr;
+	std::filesystem::create_directories(path, direrr);
+	if (direrr)
+		osd_printf_error("[xybots-capture] Error creating %s (%s)\n", capture_dir.c_str(), direrr.message().c_str());
+}
