+bool xybots_state::xybots_screen_rect(const xybots_mo_capture_record &object, const rectangle &cliprect, rectangle &rect)
+{
+	rect = rectangle(object.rendered_x, object.rendered_x + object.width_tiles * 8 - 1, object.rendered_y, object.rendered_y + object.height_tiles * 8 - 1);
+	rect &= cliprect;
+	return !rect.empty();
+}
+
+
+bool xybots_state::xybots_group_rects_touch(const rectangle &left, const rectangle &right)
+{
+	rectangle expanded(left.left() - 2, left.right() + 2, left.top() - 2, left.bottom() + 2);
+	expanded &= right;
+	return !expanded.empty();
+}
+
+
+bool xybots_state::xybots_group_rects_character_related(const rectangle &left, const rectangle &right)
+{
+	rectangle expanded(left.left() - 16, left.right() + 16, left.top() - 16, left.bottom() + 16);
+	expanded &= right;
+	if (expanded.empty())
+		return false;
+
+	rectangle bounds = left;
+	bounds |= right;
+	if (bounds.width() > 96 || bounds.height() > 112)
+		return false;
+
+	bool const horizontal_overlap = !(left.right() < right.left() || right.right() < left.left());
+	bool const vertical_overlap = !(left.bottom() < right.top() || right.bottom() < left.top());
+	if (horizontal_overlap || vertical_overlap)
+		return true;
+
+	int const left_cx = (left.left() + left.right()) / 2;
+	int const left_cy = (left.top() + left.bottom()) / 2;
+	int const right_cx = (right.left() + right.right()) / 2;
+	int const right_cy = (right.top() + right.bottom()) / 2;
+	return std::abs(left_cx - right_cx) <= 48 && std::abs(left_cy - right_cy) <= 64;
+}
+
+
+void xybots_state::xybots_blit_argb(bitmap_argb32 &dest, const bitmap_argb32 &src, int dest_x, int dest_y)
+{
+	for (int y = 0; y < src.height(); y++)
+	{
+		int const target_y = dest_y + y;
+		if (target_y < 0 || target_y >= dest.height())
+			continue;
+
+		for (int x = 0; x < src.width(); x++)
+		{
+			int const target_x = dest_x + x;
+			if (target_x < 0 || target_x >= dest.width())
+				continue;
+
+			u32 const pixel = src.pix(y, x);
+			if (rgb_t(pixel).a())
+				dest.pix(target_y, target_x) = pixel;
+		}
+	}
+}
