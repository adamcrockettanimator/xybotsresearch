+void xybots_state::xybots_collect_motion_objects(std::vector<xybots_mo_capture_record> &objects)
+{
+	u16 const *const spriteram = m_mob->spriteram();
+	objects.clear();
+	objects.reserve(64);
+
+	for (int slot = 0; slot < 64; slot++)
+	{
+		u16 const *const entry = &spriteram[slot * 4];
+		xybots_mo_capture_record object;
+		object.slot = slot;
+		object.raw = { entry[0], entry[1], entry[2], entry[3] };
+		object.code = entry[0] & 0x3fff;
+		object.color = entry[3] & 0x000f;
+		object.raw_x = (entry[3] & 0xff80) >> 7;
+		object.raw_y = (entry[2] & 0xff80) >> 7;
+		object.rendered_x = object.raw_x;
+		object.rendered_y = -object.raw_y;
+		object.width_tiles = 1;
+		object.height_tiles = (entry[2] & 0x0007) + 1;
+		object.hflip = bool(entry[0] & 0x8000);
+		object.vflip = false;
+		object.priority = entry[1] & 0x000f;
+
+		object.rendered_y -= object.height_tiles * 8;
+		object.rendered_x &= 0x1ff;
+		object.rendered_y &= 0x1ff;
+		if (object.rendered_x >= m_mob->bitmap().width())
+			object.rendered_x -= 0x200;
+		if (object.rendered_y >= m_mob->bitmap().height())
+			object.rendered_y -= 0x200;
+
+		for (int tile = 0; tile < object.height_tiles; tile++)
+			object.source_tiles.push_back(object.code + tile);
+
+		objects.push_back(std::move(object));
+	}
+}
+
+
+void xybots_state::xybots_render_object_bitmap(const xybots_mo_capture_record &object, bitmap_ind16 &bitmap)
+{
+	bitmap.fill(0xffff);
+
+	gfx_element *const gfx = m_gfxdecode->gfx(1);
+	u32 const color = 0x100 + (object.color * gfx->granularity()) + (object.priority << atari_motion_objects_device::PRIORITY_SHIFT);
+	rectangle const cliprect = bitmap.cliprect();
+
+	for (int tile = 0; tile < object.height_tiles; tile++)
+	{
+		int const local_y = object.vflip ? ((object.height_tiles - 1 - tile) * 8) : (tile * 8);
+		gfx->transpen_raw(bitmap, cliprect, object.code + tile, color, object.hflip, object.vflip, 0, local_y, 0);
+	}
+}
+
+
+void xybots_state::xybots_convert_mobitmap(bitmap_argb32 &dest, const bitmap_ind16 &src, const rectangle &cliprect)
+{
+	rgb_t const *const palette = m_screen->palette().palette()->entry_list_adjusted();
+
+	for (int y = 0; y < dest.height(); y++)
+	{
+		u32 *const dst = &dest.pix(y);
+		u16 const *const source = &src.pix(cliprect.top() + y, cliprect.left());
+		for (int x = 0; x < dest.width(); x++)
+		{
+			u16 const pixel = source[x];
+			dst[x] = (pixel == 0xffff) ? rgb_t::transparent() : palette[pixel & atari_motion_objects_device::DATA_MASK];
+		}
+	}
+}
