+
+void xybots_state::xybots_write_metadata(const char *path, const std::vector<xybots_mo_capture_record> &objects, screen_device &screen, const rectangle &cliprect, const char *capture_dir)
+{
+	rapidjson::StringBuffer buffer;
+	rapidjson::PrettyWriter<rapidjson::StringBuffer> writer(buffer);
+
+	writer.StartObject();
+	writer.Key("game");
+	writer.String("xybots");
+	writer.Key("capture_index");
+	writer.Int(m_xybots_capture_index);
+	writer.Key("emulated_frame");
+	writer.Uint64(screen.frame_number());
+	writer.Key("capture_dir");
+	writer.String(capture_dir);
+	writer.Key("trigger");
+	writer.String("MAME_XYBOTS_CAPTURE=1 and KEYCODE_F12");
+
+	writer.Key("screen");
+	writer.StartObject();
+	writer.Key("width");
+	writer.Int(cliprect.width());
+	writer.Key("height");
+	writer.Int(cliprect.height());
+	writer.EndObject();
+
+	writer.Key("motion_object_space");
+	writer.StartObject();
+	writer.Key("width");
+	writer.Int(512);
+	writer.Key("height");
+	writer.Int(512);
+	writer.EndObject();
+
+	writer.Key("objects");
+	writer.StartArray();
+	for (xybots_mo_capture_record const &object : objects)
+	{
+		writer.StartObject();
+		writer.Key("slot");
+		writer.Int(object.slot);
+
+		writer.Key("raw_words");
+		writer.StartArray();
+		for (u16 word : object.raw)
+		{
+			std::string const hex = util::string_format("0x%04X", word);
+			writer.String(hex.c_str());
+		}
+		writer.EndArray();
+
+		writer.Key("code");
+		writer.Uint(object.code);
+		writer.Key("code_hex");
+		std::string const code_hex = util::string_format("0x%04X", object.code);
+		writer.String(code_hex.c_str());
+
+		writer.Key("source_tiles");
+		writer.StartArray();
+		for (u32 tile : object.source_tiles)
+			writer.Uint(tile);
+		writer.EndArray();
+
+		writer.Key("color");
+		writer.Uint(object.color);
+		writer.Key("priority");
+		writer.Int(object.priority);
+
+		writer.Key("raw_position");
+		writer.StartObject();
+		writer.Key("x");
+		writer.Int(object.raw_x);
+		writer.Key("y");
+		writer.Int(object.raw_y);
+		writer.EndObject();
+
+		writer.Key("rendered_position");
+		writer.StartObject();
+		writer.Key("x");
+		writer.Int(object.rendered_x);
+		writer.Key("y");
+		writer.Int(object.rendered_y);
+		writer.EndObject();
+
+		writer.Key("size_tiles");
+		writer.StartObject();
+		writer.Key("width");
+		writer.Int(object.width_tiles);
+		writer.Key("height");
+		writer.Int(object.height_tiles);
+		writer.EndObject();
+
+		writer.Key("size_pixels");
+		writer.StartObject();
+		writer.Key("width");
+		writer.Int(object.width_tiles * 8);
+		writer.Key("height");
+		writer.Int(object.height_tiles * 8);
+		writer.EndObject();
+
+		writer.Key("flip");
+		writer.StartObject();
+		writer.Key("x");
+		writer.Bool(object.hflip);
+		writer.Key("y");
+		writer.Bool(object.vflip);
+		writer.EndObject();
+
+		writer.Key("visible");
+		writer.Bool(object.visible);
+		if (object.visible)
+		{
+			writer.Key("image");
+			writer.String(object.image.c_str());
+		}
+
+		writer.EndObject();
+	}
+	writer.EndArray();
+	writer.EndObject();
+
+	emu_file file(machine().options().snapshot_directory(), OPEN_FLAG_WRITE | OPEN_FLAG_CREATE | OPEN_FLAG_CREATE_PATHS);
+	std::error_condition const filerr = file.open(path);
+	if (filerr)
+	{
+		osd_printf_error("[xybots-capture] Error opening %s (%s)\n", path, filerr.message().c_str());
+		return;
+	}
+	auto const [writeerr, actual] = util::write(file, buffer.GetString(), buffer.GetSize());
+	if (writeerr || (actual != buffer.GetSize()))
+		osd_printf_error("[xybots-capture] Error writing %s (%s)\n", path, writeerr.message().c_str());
+}
