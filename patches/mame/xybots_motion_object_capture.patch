+void xybots_state::xybots_capture_frame(screen_device &screen, const rectangle &cliprect)
+{
+	std::vector<xybots_mo_capture_record> objects;
+	xybots_collect_motion_objects(objects);
+
+	m_xybots_capture_index++;
+	std::string const capture_dir = util::string_format("xybots_capture/capture_%04d", m_xybots_capture_index);
+	xybots_create_capture_dirs(capture_dir, true);
+
+	bitmap_argb32 sprite_layer(cliprect.width(), cliprect.height());
+	xybots_convert_mobitmap(sprite_layer, m_mob->bitmap(), cliprect);
+	xybots_write_png((capture_dir + "/sprite_layer.png").c_str(), sprite_layer);
+
+	int visible_objects = 0;
+	for (xybots_mo_capture_record &object : objects)
+	{
+		bitmap_ind16 object_ind(object.width_tiles * 8, object.height_tiles * 8);
+		xybots_render_object_bitmap(object, object_ind);
+		object.visible = xybots_bitmap_has_pixels(object_ind);
+
+		if (object.visible)
+		{
+			visible_objects++;
+			object.image = util::string_format("objects/slot_%02d.png", object.slot);
+
+			bitmap_argb32 object_argb(object_ind.width(), object_ind.height());
+			xybots_convert_mobitmap(object_argb, object_ind, object_ind.cliprect());
+			xybots_write_png((capture_dir + "/" + object.image).c_str(), object_argb);
+		}
+	}
+
+	xybots_write_debug_layer((capture_dir + "/sprite_layer_debug.png").c_str(), sprite_layer, objects);
+	xybots_write_metadata((capture_dir + "/metadata.json").c_str(), objects, screen, cliprect, capture_dir.c_str());
+
+	osd_printf_info("[xybots-capture] Capturing frame %llu\n", (unsigned long long)screen.frame_number());
+	osd_printf_info("[xybots-capture] 64 slots, %d visible objects\n", visible_objects);
+	osd_printf_info("[xybots-capture] Wrote %s\n", capture_dir.c_str());
+}
